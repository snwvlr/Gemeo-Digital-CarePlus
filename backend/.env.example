# ===== CarePlus Gêmeo Digital · variáveis de ambiente =====
# Copie este arquivo para ".env" e preencha com seus valores.
# NUNCA faça commit do arquivo .env real.

# Chave da API do Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Modelo (Tier 1 já dá acesso ao 2.5 Flash)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=2048

# Configuração da aplicação
DEBUG=false

# Proteção da API de IA (anti-abuso): chamadas ao Gemini por IP
AI_RATE_MAX=20
AI_RATE_WINDOW_SECONDS=60

# Portão de acesso ao site (para apresentar em domínio público)
# AUTH_ENABLED=true exige senha para abrir o site. A senha vira um token
# em cookie httpOnly (não acessível por JavaScript, resistente a XSS).
AUTH_ENABLED=false
SITE_PASSWORD=
# Troque por um valor longo e secreto antes de publicar:
AUTH_SECRET=careplus-altere-este-segredo

